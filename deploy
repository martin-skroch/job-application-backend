#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")"

fail() {
    echo "❌ Error: $1" >&2
    exit 1
}

if [ ! -f .env ]; then
    fail "The .env file required for deployment does not exist."
fi

source .env

if [ "$APP_ENV" == "local" ]; then
    fail "Deployment aborted: APP_ENV must not be 'local'."
fi

# $PHP_BIN artisan down --refresh=15 --retry=60

echo "📦 Pulling latest code..."
git reset --hard || fail "git reset --hard failed."
git clean -d -f || fail "git clean failed."
git pull origin master --rebase || fail "git pull failed."

echo "📦 Installing Composer dependencies..."
$COMPOSER_BIN install --no-dev --no-interaction --prefer-dist --optimize-autoloader || fail "Composer install failed."

echo "🎨 Building frontend assets..."
npm ci --audit false || fail "npm ci failed."
npm run build || fail "npm run build failed."

if [ -z "${APP_KEY}" ]; then
    echo "🔑 Generating application key..."
    $PHP_BIN artisan key:generate --ansi || fail "key:generate failed."
fi

if [ ! -L "./public/storage" ]; then
    echo "🔗 Creating storage link..."
    $PHP_BIN artisan storage:link --relative || fail "storage:link failed."
fi

echo "🗄️  Running migrations..."
$PHP_BIN artisan migrate --force || fail "Migrations failed."

echo "⚡ Caching routes, events and views..."
$PHP_BIN artisan optimize:clear || fail "optimize:clear failed."
# $PHP_BIN artisan optimize
$PHP_BIN artisan event:cache || fail "event:cache failed."
$PHP_BIN artisan route:cache || fail "route:cache failed."
$PHP_BIN artisan view:cache || fail "view:cache failed."
# $PHP_BIN artisan icons:cache

echo "🚀 Application deployed!"
